{
  "name": "mssql-performance-skills-mcp",
  "version": "1.0.0",
  "description": "Remote MCP server exposing 19 SQL Server performance tuning skills — deployed on Cloudflare Workers",
  "scripts": {
    "bundle": "tsx scripts/bundle-skills.ts",
    "dev": "npm run bundle && wrangler dev",
    "deploy": "npm run bundle && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["mcp", "sql-server", "mssql", "performance", "t-sql", "cloudflare-workers"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250522.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
