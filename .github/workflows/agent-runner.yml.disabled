# CLOUD MODE (OPT-IN, disabled by default) — rename to agent-runner.yml
# to enable.
#
# Runs bounded worker/review batches inside GitHub Actions on a cron, so
# you need NO self-hosted machine at all. Understand the trade-off first:
#
#   This puts a MODEL API KEY into repository secrets, breaking the
#   default posture that model credentials never touch CI. One leaked
#   secret (or one malicious workflow change that exfiltrates it) can
#   spend your whole model budget. Compensating controls here: bounded
#   batches (AW_MAX), the review loop's separate identity, and CODEOWNERS
#   on .github/workflows/. Prefer self-hosted runners (deploy/) when you
#   can.
#
# Required secrets:
#   ANTHROPIC_API_KEY     — model key for the claude CLI
#   REVIEW_GITHUB_TOKEN   — second GitHub identity's PAT for the reviewer
#                           job (worker uses the ambient GITHUB_TOKEN)

name: agent-runner

on:
  schedule:
    - cron: "*/30 * * * *"
  workflow_dispatch:

permissions:
  contents: write
  issues: write
  pull-requests: write
  statuses: write

concurrency:
  group: aw-agent-runner
  cancel-in-progress: false

jobs:
  work:
    runs-on: ubuntu-latest
    timeout-minutes: 55
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install agent CLI
        run: npm install -g @anthropic-ai/claude-code

      - name: Worker batch
        env:
          GH_TOKEN: ${{ github.token }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          AW_REPO: ${{ github.repository }}
          AW_AGENT: claude
          AW_MAX: "2"
          AW_POLL_SECONDS: "0"
          AW_AGENT_TIMEOUT: "1500"
        run: ./scripts/start_work.sh

  review:
    runs-on: ubuntu-latest
    timeout-minutes: 55
    needs: work
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install agent CLI
        run: npm install -g @anthropic-ai/claude-code

      - name: Review batch
        env:
          REVIEW_GITHUB_TOKEN: ${{ secrets.REVIEW_GITHUB_TOKEN }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          AW_REPO: ${{ github.repository }}
          AW_AGENT: claude
          AW_MAX: "2"
          AW_POLL_SECONDS: "0"
          AW_AGENT_TIMEOUT: "1500"
        run: ./scripts/review_work.sh
