# /etc/agentworks/aw.env — environment for the systemd units.
# chmod 600, owned by the runner user. NEVER commit a filled-in copy.

AW_REPO=owner/name
AW_AGENT=claude
# AW_MODEL=
# AW_MAX=0
# AW_LOG_FORMAT=json
# AW_LOG_FILE=/var/log/agentworks/aw.log
AW_SINGLE_INSTANCE=1

# reviewer identity (aw-reviewer.service) — one of:
# REVIEW_GITHUB_TOKEN=ghp_...
# AW_ALLOW_SOLO_REVIEW=1
